#:kivy 2.3.0

<Label>:
    color: 1, 1, 1, 1
    font_size: 18

<TextInput>:
    background_color: 0.12, 0.12, 0.12, 1
    foreground_color: 1, 1, 1, 1
    padding: 10
    font_size: 16
    size_hint_y: None
    height: 42
    cursor_color: 0, 1, 0.4, 1

<Button>:
    background_normal: ""
    background_color: 0, 0.78, 0.32, 1
    color: 1, 1, 1, 1
    font_size: 16
    size_hint_y: None
    height: 48
    canvas.before:
        Color:
            rgba: self.background_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10,]
        Color:
            rgba: 0, 0, 0, 0.15
        RoundedRectangle:
            pos: self.x, self.y - 2
            size: self.size
            radius: [10,]

<GradientBackground>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            texture: self.gradient_texture
    gradient_texture: self.create_gradient_texture()
    on_size: self.gradient_texture = self.create_gradient_texture()

<LoginScreen>:
    FloatLayout:
        GradientBackground:
            size: root.size
            pos: root.pos

        BoxLayout:
            orientation: "vertical"
            size_hint: 0.4, 0.6
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            padding: 30
            spacing: 15
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.4
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20,]

            Label:
                text: "🏋️‍♂️ Fitness Tracker"
                font_size: 28
                bold: True

            TextInput:
                id: username
                hint_text: "Uživatelské jméno"

            TextInput:
                id: password
                hint_text: "Heslo"
                password: True
            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: 32
                spacing: 8
                Label:
                    text: "Autologin"
                    size_hint_x: 0.7
                    font_size: 14
                    color: 0.8,0.8,0.8,1
                CheckBox:
                    id: remember_me
                    size_hint_x: 0.3

            Button:
                text: "Přihlásit se"
                on_release: root.login()


<MainScreen>:
    BoxLayout:
        spacing: 0
        
        # Navigation Sidebar
        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.2
            padding: 20
            spacing: 15
            canvas.before:
                Color:
                    rgba: 0.12, 0.12, 0.12, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "🏋️‍♂️ Fitness"
                font_size: 24
                bold: True
                size_hint_y: None
                height: 40

            Label:
                text: root.username
                font_size: 18
                size_hint_y: None
                height: 30

            Widget:
                size_hint_y: 0.1

            Button:
                text: "🎯 Tréninky"
                background_color: (0, 0.78, 0.32, 1) if sm_content.current == "workouts" else (0.2, 0.2, 0.2, 1)
                on_release: sm_content.current = "workouts"

            Button:
                text: "📊 Statistiky"
                background_color: (0, 0.78, 0.32, 1) if sm_content.current == "stats" else (0.2, 0.2, 0.2, 1)
                on_release: sm_content.current = "stats"
            Button:
                text: "🔧 Admin"
                background_color: (0, 0.78, 0.32, 1) if sm_content.current == "admin" else (0.2, 0.2, 0.2, 1)
                on_release: sm_content.current = "admin"
                disabled: not root.is_admin
                opacity: 1 if root.is_admin else 0

            Widget:
                size_hint_y: 1

            Button:
                text: "⬅️ Odhlásit se"
                background_color: 1, 0.25, 0.25, 1
                on_release: root.logout()

        # Main Content Area (full-screen sections via ScreenManager)
        ScreenManager:
            id: sm_content
            WorkoutsScreen:
                name: "workouts"
                id: workouts_screen
            StatsScreen:
                name: "stats"
                id: stats_screen
            AdminScreen:
                name: "admin"
                id: admin_screen


<WorkoutsScreen>:
    BoxLayout:
        orientation: "horizontal"
        spacing: 0
        padding: 0

        # Main content area (left). When panel opens this shrinks to 70%.
        BoxLayout:
            id: main_area
            orientation: "vertical"
            spacing: 12
            padding: 16
            size_hint_x: 0.7 if root.show_exercises else 1

            BoxLayout:
                orientation: "vertical"
                spacing: 20
                size_hint_y: None
                height: self.minimum_height

                Button:
                    text: "📋 Vybrat cvik" if not root.selected_exercise else root.selected_exercise
                    size_hint_y: None
                    height: 48
                    on_release: root.toggle_exercise_list()

                BoxLayout:
                    spacing: 15
                    size_hint_y: None
                    height: 48
                    TextInput:
                        id: sets
                        hint_text: "Série"
                        input_filter: "int"
                    TextInput:
                        id: reps
                        hint_text: "Opakování"
                        input_filter: "int"
                    TextInput:
                        id: weight
                        hint_text: "Váha (kg)"
                        input_filter: "int"

            Button:
                text: "✅ Přidat do tréninku"
                size_hint_y: None
                height: 48
                on_release: root.add_exercise()

            BoxLayout:
                spacing: 10
                size_hint_y: None
                height: 48

                Button:
                    text: "💾 Uložit trénink"
                    on_release: root.save_workout()

                Button:
                    text: "🗑️ Smazat poslední"
                    background_color: 0.8, 0.2, 0.2, 1
                    on_release: root.remove_last()

            ScrollView:
                TextInput:
                    id: workout_list
                    size_hint: 1, None
                    height: max(self.minimum_height, 200)
                    readonly: True
                    multiline: True

            TextInput:
                id: note
                hint_text: "Poznámka k tréninku (volitelné)"
                size_hint_y: None
                height: 80
                multiline: True

        # Right-side exercise panel. When hidden it collapses to 0 width and won't cover the main area.
        BoxLayout:
            id: exercise_panel
            orientation: "vertical"
            size_hint_x: 0.3 if root.show_exercises else 0
            padding: [10, 20, 10, 20]
            spacing: 10
            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10, 0, 0, 10]
            opacity: 1 if root.show_exercises else 0
            disabled: not root.show_exercises

            Label:
                text: "Seznam cviků"
                font_size: 20
                size_hint_y: None
                height: 30
                bold: True

            ScrollView:
                do_scroll_x: False
                BoxLayout:
                    id: exercise_list
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 5

            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: 48
                spacing: 8
                TextInput:
                    id: new_exercise
                    hint_text: "Nový cvik"
                    size_hint_x: 0.7
                    input_filter: None
                Button:
                    text: "➕"
                    size_hint_x: 0.3
                    on_release: root.add_custom_exercise()


<StatsScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 12
        spacing: 10

        # --- Top Bar: Weight Input ---
        BoxLayout:
            size_hint_y: None
            height: 50
            spacing: 10
            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10,]
            padding: 10

            Label:
                id: weight_label
                text: "Váha: " + (str(root.user_weight) + " kg" if root.user_weight else "--")
                size_hint_x: 0.4
                color: 0.7, 0.7, 0.7, 1
            
            TextInput:
                id: weight_input
                hint_text: "Nová váha"
                input_filter: "float"
                multiline: False
                size_hint_x: 0.3
                background_color: 0.1, 0.1, 0.1, 1
                
            Button:
                text: "Zapsat"
                size_hint_x: 0.3
                background_color: 0, 0.5, 1, 1
                on_release: root.update_weight()

        BoxLayout:
            size_hint_y: None
            height: 50
            spacing: 10
            padding: [10, 0, 10, 0]
            Button:
                text: "📉 Tělesná váha"
                background_color: 0, 0.5, 1, 1
                on_release: root.show_bodyweight_stats()
            Button:
                id: btn_select_ex
                text: "🏋️ Vybrat cvik"
                on_release: root.toggle_stat_exercise_list()

        BoxLayout:
            spacing: 12
            size_hint_y: 1
            RelativeLayout:
                size_hint_x: 0.75
                GraphWidget:
                    id: graph
                    size_hint: 1, 1
            BoxLayout:
                orientation: "vertical"
                size_hint_x: 0.25
                spacing: 10
                canvas.before:
                    Color:
                        rgba: 0.1, 0.1, 0.1, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10,]
                padding: 10
                Label:
                    text: root.selected_stat_item
                    size_hint_y: None
                    height: 30
                    bold: True
                    font_size: 20
                GridLayout:
                    cols: 1
                    spacing: 10
                    size_hint_y: 1
                    BoxLayout:
                        orientation: "vertical"
                        padding: 5
                        canvas.before:
                            Color:
                                rgba: 0.15, 0.15, 0.15, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [8,]
                        Label:
                            text: "PR / Peak"
                            font_size: 12
                            color: 0.6, 0.6, 0.6, 1
                        Label:
                            text: root.metric_peak if root.stat_mode == "bodyweight" else root.metric_pr
                            font_size: 20
                            bold: True
                            color: 0, 0.8, 0.4, 1
                    BoxLayout:
                        orientation: "vertical"
                        padding: 5
                        canvas.before:
                            Color:
                                rgba: 0.15, 0.15, 0.15, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [8,]
                        Label:
                            text: "Průměr (měsíc)"
                            font_size: 12
                            color: 0.6, 0.6, 0.6, 1
                        Label:
                            text: root.metric_avg
                            font_size: 20
                            bold: True
                            color: 1, 0.8, 0, 1
                    BoxLayout:
                        orientation: "vertical"
                        padding: 5
                        canvas.before:
                            Color:
                                rgba: 0.15, 0.15, 0.15, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [8,]
                        Label:
                            text: "Low / Min"
                            font_size: 12
                            color: 0.6, 0.6, 0.6, 1
                        Label:
                            text: root.metric_low
                            font_size: 20
                            bold: True
                            color: 0.2, 0.6, 1, 1
                # Exercise list on the right under metrics
                ScrollView:
                    do_scroll_x: False
                    opacity: 1 if root.show_stat_exercises else 0
                    disabled: not root.show_stat_exercises
                    BoxLayout:
                        id: stat_exercise_list
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: 6
                

<AdminScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 12
        spacing: 10
        BoxLayout:
            size_hint_y: None
            height: 40
            spacing: 8
            Button:
                text: "Exportovat audit (CSV)"
                on_release: root.export_audit()
            Button:
                text: "VYČISTIT SEZNAM CVIKŮ"
                background_color: 0.8, 0, 0, 1
                on_release: root.confirm_clear_all_exercises()
        BoxLayout:
            size_hint_y: None
            height: 48
            spacing: 10
            TextInput:
                hint_text: "Hledat cvik..."
                on_text: root.on_search_exercise(self, self.text)
            TextInput:
                hint_text: "Hledat účet..."
                on_text: root.on_search_user(self, self.text)
        BoxLayout:
            orientation: "horizontal"
            spacing: 10
            BoxLayout:
                orientation: "vertical"
                size_hint_x: 0.5
                Label:
                    text: "Centrální seznam cviků"
                    size_hint_y: None
                    height: 30
                    bold: True
                ScrollView:
                    do_scroll_x: False
                    BoxLayout:
                        id: admin_exercise_list
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: 6
            BoxLayout:
                orientation: "vertical"
                size_hint_x: 0.5
                Label:
                    text: "Uživatelské účty"
                    size_hint_y: None
                    height: 30
                    bold: True
                ScrollView:
                    do_scroll_x: False
                    BoxLayout:
                        id: admin_user_list
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: 6

